generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model PdfRecord {
  id              String   @id @default(uuid())
  originalName    String
  modifiedName    String
  lastPingAt      DateTime @default(now())
  createdAt       DateTime @default(now())
}
