generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PdfRecord {
  id              String   @id @default(uuid())
  originalName    String
  modifiedName    String
  lastPingAt      DateTime @default(now())
  createdAt       DateTime @default(now())
}
